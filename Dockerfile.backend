# ── Stage 1: Builder ──────────────────────────────────────────
# Install dependencies in isolation — only reruns when
# requirements.txt changes, not on every code change
FROM python:3.11-slim AS builder

WORKDIR /app

# Install system deps needed by some Python packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt


# ── Stage 2: Runtime ──────────────────────────────────────────
FROM python:3.11-slim

WORKDIR /app

# Copy installed packages from builder
COPY --from=builder /install /usr/local

# Copy only what the backend needs
COPY main.py .
COPY config.py .
COPY app/ ./app/
COPY utils/ ./utils/

# Don't run as root
RUN useradd -m -u 1000 appuser && chown -R appuser /app
USER appuser

EXPOSE 8080

# --host 0.0.0.0 required — without it uvicorn only
# listens on localhost inside the container
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080"]